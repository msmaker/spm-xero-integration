        <value>  (function execute(inputs, outputs) {&#13;
    try {&#13;
        // 1. Criar o lote de importação (Import Set)&#13;
        var importSetGR = new GlideRecord('sys_import_set');&#13;
        importSetGR.initialize();&#13;
        importSetGR.mode = 'synchronous'; &#13;
        importSetGR.table_name = 'imp_rate_model_line'; // Usando a tabela nativa do seu arquivo&#13;
        importSetGR.state = 'loading';&#13;
        var importSetSysId = importSetGR.insert();&#13;
&#13;
        // 2. Inserir a linha com os dados mapeados do Xero&#13;
        var stagingGR = new GlideRecord('imp_rate_model_line');&#13;
        stagingGR.initialize();&#13;
        stagingGR.sys_import_set = importSetSysId;&#13;
        &#13;
        // Mapeando as variáveis que vieram dos Inputs da sua Action&#13;
        stagingGR.u_rate = inputs.rate;                      // Ex: 150.00&#13;
        stagingGR.u_resource_role = inputs.resource_role;    // SysID ou String da Role&#13;
        stagingGR.u_rate_model = inputs.rate_model;          // SysID do Modelo de Taxa&#13;
        stagingGR.u_start_date = inputs.start_date;          // Data de início (YYYY-MM-DD)&#13;
        &#13;
        // Se você tiver um ID único da task do Xero para evitar duplicados, adicione aqui:&#13;
        // stagingGR.u_xero_task_id = inputs.xero_task_id; &#13;
&#13;
        var stagingSysId = stagingGR.insert();&#13;
&#13;
        // Atualizar o estado do lote para carregado&#13;
        importSetGR.get(importSetSysId);&#13;
        importSetGR.state = 'loaded';&#13;
        importSetGR.update();&#13;
&#13;
        // 3. Disparar o Transform Map nativo&#13;
        var tU = new sn_impex.TransformerAPI();&#13;
        var transformMapSysId = "79d492d6734023005cbb2b158bf6a7cf"; // SysID do seu Rate Model Line Transform Map&#13;
        tU.transformImportSet(transformMapSysId, importSetSysId);&#13;
&#13;
        outputs.status = "Success";&#13;
    } catch (ex) {&#13;
        outputs.status = "Erro: " + ex.message;&#13;
        gs.error("Erro na Flow Action do Xero: " + ex.message);&#13;
    }&#13;
})(inputs, outputs);&#13;
</value>
